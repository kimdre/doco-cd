package provider

import (
	"errors"
	"os"
)

const (
	// Example env vars; replace with provider-specific names.
	envEndpoint = "__PROVIDER_NAME___ENDPOINT"
	envToken    = "__PROVIDER_NAME___TOKEN"
)

type Config struct {
	Endpoint string
	Token    string
}

func GetConfig() (Config, error) {
	cfg := Config{
		Endpoint: os.Getenv(envEndpoint),
		Token:    os.Getenv(envToken),
	}

	if cfg.Endpoint == "" {
		return Config{}, errors.New(envEndpoint + " is required")
	}

	if cfg.Token == "" {
		return Config{}, errors.New(envToken + " is required")
	}

	return cfg, nil
}

